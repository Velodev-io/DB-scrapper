{
  "name": "@carry/agent-native",
  "version": "0.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev": "eas build --profile development --platform android --local",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "submit": "eas submit --platform android",
    "update": "eas update --branch production",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@carry/logic": "*",
    "@carry/shared": "*",
    "@clerk/clerk-expo": "^2.19.31",
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-background-fetch": "~14.0.9",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
